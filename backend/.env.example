# ============================================================
# MedSync AI — Backend Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only commit .env.example
# ============================================================

# -----------------------------------------------------------
# Gemini AI  (required)
# Get your key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use — gemini-2.5-flash is the recommended default
GEMINI_MODEL=gemini-2.5-flash

# Per-request timeout in seconds
GEMINI_TIMEOUT=30

# -----------------------------------------------------------
# Simulation Mode
# When true → Gemini is NOT required; deterministic fallbacks
# are used automatically. Set to false in production.
# -----------------------------------------------------------
SIMULATION_MODE=false

# -----------------------------------------------------------
# App
# -----------------------------------------------------------
DEBUG=true

# -----------------------------------------------------------
# Database (optional for MVP — only needed if you connect DB)
# -----------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=medsync_db
