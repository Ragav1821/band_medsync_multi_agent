# ============================================================
# MedSync AI — .gitignore
# ============================================================

# ── Python / Backend ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak

# Environment files — NEVER commit real secrets
.env
.env.local
.env.production
backend/.env
backend/.env.local

# Python test/coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# Frontend env files
frontend/.env
frontend/.env.local
frontend/.env.production

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.DS_Store
Thumbs.db

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Secrets / Keys ───────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
